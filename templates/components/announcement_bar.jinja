<!-- Announcement Bar with rotating messages -->
<div class="announcement-bar text-white text-center py-2.5 text-xs font-medium tracking-widest uppercase relative overflow-hidden"
     x-data="{ messages: ['No tariff or duty — all included in price.', 'Enjoy Free Insured Worldwide Shipping', 'IGI & GIA Certified Lab-Grown Diamonds', 'Purchase $3000+ and get a FREE Stud Earring'], current: 0, interval: null }"
     x-init="interval = setInterval(() => { current = (current + 1) % messages.length }, 3500)">

  <!-- Social Icons Left -->
  <div class="absolute left-4 top-1/2 -translate-y-1/2 hidden lg:flex items-center gap-3">
    <a href="tel:+918238366075" class="flex items-center gap-1.5 opacity-80 hover:opacity-100 transition-opacity">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
      <span class="text-xs">+91 82383 66075</span>
    </a>
    <a href="mailto:{{ site_email }}" class="flex items-center gap-1.5 opacity-80 hover:opacity-100 transition-opacity">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <span class="text-xs">Mail Us</span>
    </a>
  </div>

  <!-- Rotating message with prev/next arrows -->
  <div class="flex items-center justify-center gap-4">
    <button @click="current = (current - 1 + messages.length) % messages.length" class="opacity-60 hover:opacity-100">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <div class="relative overflow-hidden min-w-0">
      <template x-for="(msg, i) in messages" :key="i">
        <div x-show="current === i"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-2"
             x-transition:enter-end="opacity-100 translate-y-0"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-end="opacity-0 -translate-y-2"
             class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 flex-shrink-0 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span x-text="msg"></span>
        </div>
      </template>
    </div>
    <button @click="current = (current + 1) % messages.length" class="opacity-60 hover:opacity-100">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <!-- Social icons right -->
  <div class="absolute right-4 top-1/2 -translate-y-1/2 hidden lg:flex items-center gap-2.5 opacity-80">
    <a href="#" class="hover:opacity-100 transition-opacity"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
