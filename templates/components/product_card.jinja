<!-- Product Card Component -->
{% macro product_card(product) %}
<div class="product-card group relative">
  <!-- Wishlist / Heart -->
  <button class="absolute top-3 right-3 z-10 w-8 h-8 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center shadow-sm opacity-0 group-hover:opacity-100 transition-all duration-200 hover:bg-white hover:text-red-500 text-gray-500"
          hx-post="{{ url('users:wishlist_toggle', product_id=product.id) }}"
          hx-swap="none"
          aria-label="Add to Wishlist">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
  </button>

  <!-- Badges -->
  <div class="absolute top-3 left-3 z-10 flex flex-col gap-1">
    {% if product.is_new_arrival %}
      <span class="bg-navy-700 text-white text-xs px-2 py-0.5 font-medium tracking-wider">NEW</span>
    {% endif %}
    {% if product.discount_percent > 0 %}
      <span class="bg-red-600 text-white text-xs px-2 py-0.5 font-medium">-{{ product.discount_percent }}%</span>
    {% endif %}
    {% if product.certification and product.certification != 'none' %}
      <span class="bg-gold-500 text-white text-xs px-2 py-0.5 font-medium uppercase">{{ product.certification }}</span>
    {% endif %}
  </div>

  <!-- Product Image -->
  <a href="{{ url('products:detail', slug=product.slug) }}" class="block overflow-hidden bg-gray-50 aspect-square">
    {% if product.primary_image %}
      <img src="{{ product.primary_image.image.url }}" alt="{{ product.primary_image.alt or product.name }}"
           class="product-img w-full h-full object-cover">
    {% else %}
      {#
        Smart Unsplash fallback images based on product category.
        Verified working jewelry photo IDs from Unsplash:
      #}
      {% set _cat = product.category.name %}
      {% if _cat == 'Engagement Rings' %}
        {% set _img = 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=600&q=80&fit=crop&crop=center' %}
      {% elif _cat == 'Toi Et Moi Rings' %}
        {% set _img = 'https://images.unsplash.com/photo-1529921879218-f99546dae8b6?w=600&q=80&fit=crop&crop=center' %}
      {% elif _cat == 'Lab-Grown Diamonds' %}
        {% set _img = 'https://images.unsplash.com/photo-1563396983906-b3795482a59a?w=600&q=80&fit=crop&crop=center' %}
      {% elif _cat == 'Necklaces' %}
        {% set _img = 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=600&q=80&fit=crop&crop=center' %}
      {% elif _cat == 'Earrings' %}
        {% set _img = 'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=600&q=80&fit=crop&crop=center' %}
      {% elif _cat == 'Bracelets' %}
        {% set _img = 'https://images.unsplash.com/photo-1573408301185-9519f94533f0?w=600&q=80&fit=crop&crop=center' %}
      {% else %}
        {% set _img = 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=600&q=80&fit=crop&crop=center' %}
      {% endif %}
      <img src="{{ _img }}"
           alt="{{ product.name }}"
           class="product-img w-full h-full object-cover"
           loading="lazy">
    {% endif %}
  </a>

  <!-- Product Info -->
  <div class="pt-3 pb-1">
    <a href="{{ url('products:detail', slug=product.slug) }}">
      <h3 class="text-xs font-medium tracking-wider uppercase text-gray-800 hover:text-navy-700 transition-colors leading-relaxed line-clamp-2">
        {{ product.name }}
      </h3>
    </a>
    <div class="flex items-center gap-2 mt-1.5">
      <span class="text-sm font-medium text-gray-900">From Rs. {{ "{:,.2f}".format(product.price) }} INR</span>
      {% if product.compare_price %}
        <span class="text-xs text-gray-400 line-through">Rs. {{ "{:,.2f}".format(product.compare_price) }}</span>
      {% endif %}
    </div>
    <!-- Metal & Shape tags -->
    {% if product.metal_type or product.diamond_shape %}
    <div class="flex gap-1 mt-1.5 flex-wrap">
      {% if product.diamond_shape %}
        <span class="text-xs text-gray-400 italic">{{ product.get_diamond_shape_display() }}</span>
      {% endif %}
      {% if product.metal_type %}
        <span class="text-xs text-gray-400">· {{ product.get_metal_type_display() }}</span>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>
{% endmacro %}
