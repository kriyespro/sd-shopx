<!-- Newsletter Popup - shows once via Alpine.js + localStorage -->
<div x-data="{
    show: false,
    init() {
        if (!localStorage.getItem('newsletter_dismissed')) {
            setTimeout(() => this.show = true, 3000);
        }
    },
    dismiss() {
        this.show = false;
        localStorage.setItem('newsletter_dismissed', '1');
    }
}" x-cloak>
  <div x-show="show"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
    <div class="bg-white max-w-xl w-full shadow-2xl overflow-hidden relative"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         @click.stop>
      <button @click="dismiss()" class="absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center text-gray-500 hover:text-gray-900 bg-white rounded-full shadow">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <div class="flex">
        <!-- Left: Red promo banner -->
        <div class="w-5/12 bg-red-600 flex flex-col items-center justify-center p-6 text-white text-center">
          <p class="text-xs tracking-widest uppercase mb-2 opacity-90">Special Offer</p>
          <h2 class="font-serif text-2xl font-bold leading-tight mb-4">Valentine's Day Sale</h2>
          <div class="border-4 border-white/30 px-6 py-4 text-center">
            <p class="font-bold text-4xl leading-none">10%</p>
            <p class="text-xl font-bold">OFF</p>
          </div>
        </div>
        <!-- Right: Email signup -->
        <div class="flex-1 p-8 flex flex-col items-center justify-center">
          <h3 class="font-serif text-2xl font-bold text-navy-800 text-center mb-2">Get 10% Off on<br>Entire Order</h3>
          <p class="text-sm text-gray-500 text-center mb-6">Sign up to receive your discount.</p>
          <form class="w-full space-y-3" hx-post="#" hx-swap="none" @submit.prevent="dismiss()">
            {{ csrf_input(request) }}
            <input type="email" name="email" placeholder="Email"
                   class="w-full border border-gray-300 px-4 py-3 text-sm outline-none focus:border-navy-700 transition-colors">
            <button type="submit" class="btn-navy w-full">Sign Me Up!</button>
          </form>
          <button @click="dismiss()" class="mt-4 text-xs tracking-widest uppercase text-gray-400 hover:text-gray-700 transition-colors">NO, THANKS</button>
        </div>
      </div>
    </div>
  </div>
</div>
