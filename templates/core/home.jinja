{% extends "base.jinja" %}
{% from 'components/product_card.jinja' import product_card %}

{% block title %}{{ site_brand }} — {{ site_tagline }}{% endblock %}

{% block content %}

<!-- HERO SECTION -->
<section class="relative min-h-[90vh] flex items-end pb-20 overflow-hidden">
  <!-- Real jewelry hero background from Unsplash -->
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=1600&q=85&fit=crop&crop=center"
         alt="Luxury diamond engagement ring"
         class="w-full h-full object-cover object-center"
         loading="eager">
    <!-- Overlay gradient -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
  </div>

  <!-- Hero content -->
  <div class="relative z-10 max-w-screen-xl mx-auto px-6 w-full">
    <div class="max-w-2xl">
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-white/80 mb-4">Welcome to {{ site_brand }}</p>
      <h1 class="font-serif text-5xl md:text-7xl text-white leading-tight mb-2">
        IGI / GIA Certified
      </h1>
      <div class="relative inline-block mb-6">
        <h2 class="font-serif text-5xl md:text-6xl italic text-white/95 leading-tight">
          Fine Jewelry
        </h2>
        <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gold-500 opacity-80"></div>
      </div>
      <p class="text-base text-white/80 max-w-xl leading-relaxed mb-8">
        Purchase $3,000 USD or more and receive a Stud Earring valued at $700 USD absolutely free!
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/shop/collection/engagement-rings/" class="btn-outline btn-outline-white">
          Begin with a Setting &rarr;
        </a>
        <a href="/shop/collection/lab-grown-diamonds/" class="btn-outline btn-outline-white">
          Begin with a Stone &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<section class="bg-white border-b border-gray-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
      {% for icon, title, desc in [
        ('M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', 'IGI/GIA Certified', 'All diamonds certified'),
        ('M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z', 'Free Worldwide Shipping', 'Fully insured delivery'),
        ('M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', 'No Hidden Duties', 'Price includes all taxes'),
        ('M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', 'Made with Love', 'Handcrafted fine jewelry'),
      ] %}
      <div class="flex items-center gap-4 px-6 py-5">
        <svg class="w-8 h-8 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ icon }}"/></svg>
        <div>
          <p class="text-xs font-semibold tracking-wider uppercase text-navy-800">{{ title }}</p>
          <p class="text-xs text-gray-500">{{ desc }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- SHOP BY SHAPE — Lab-Grown Diamonds -->
<section class="py-20 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-3">Shop by Shape</p>
      <h2 class="font-serif text-4xl text-navy-800">Lab-Grown Diamonds</h2>
    </div>

    <!-- Diamond shapes horizontal scroll -->
    <div class="flex items-center justify-between gap-4 overflow-x-auto pb-4 scrollbar-hide">
      {% set shapes = [
        ('round', 'Round', '⬤'),
        ('oval', 'Oval', '⬭'),
        ('pear', 'Pear', '🍐'),
        ('cushion', 'Cushion', '⊡'),
        ('emerald', 'Emerald', '▭'),
        ('heart', 'Heart', '♥'),
        ('radiant', 'Radiant', '◇'),
        ('marquise', 'Marquise', '◇'),
      ] %}
      {% for shape, label, icon in shapes %}
      <a href="/shop/?shape={{ shape }}"
         class="flex flex-col items-center gap-4 group min-w-[90px] hover:opacity-80 transition-opacity">
        <!-- Shape icon placeholder - clean geometric -->
        <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow border border-gray-100">
          <div class="w-14 h-14 md:w-16 md:h-16 bg-gradient-to-br from-slate-200 to-slate-300 rounded-full flex items-center justify-center" style="border-radius: {% if shape == 'oval' %}50%/40%{% elif shape == 'pear' %}50% 50% 50% 50% / 60% 60% 40% 40%{% elif shape == 'emerald' %}2px{% elif shape == 'heart' %}50% 50% 0 0{% else %}50%{% endif %}">
            <svg class="w-8 h-8 text-slate-600" fill="currentColor" viewBox="0 0 24 24">
              {% if shape == 'round' %}<circle cx="12" cy="12" r="8"/>
              {% elif shape == 'oval' %}<ellipse cx="12" cy="12" rx="8" ry="6"/>
              {% elif shape == 'pear' %}<path d="M12 4c-2.5 0-5 2-5 5 0 4 5 11 5 11s5-7 5-11c0-3-2.5-5-5-5z"/>
              {% elif shape == 'cushion' %}<rect x="4" y="4" width="16" height="16" rx="4"/>
              {% elif shape == 'emerald' %}<rect x="3" y="6" width="18" height="12" rx="2"/>
              {% elif shape == 'heart' %}<path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
              {% elif shape == 'radiant' %}<polygon points="7,3 17,3 21,12 17,21 7,21 3,12"/>
              {% else %}<ellipse cx="12" cy="12" rx="5" ry="9"/>
              {% endif %}
            </svg>
          </div>
        </div>
        <span class="text-xs font-light italic text-gray-700 text-center tracking-wide">{{ label }}</span>
      </a>
      {% endfor %}
    </div>

    <!-- Slider indicator dots -->
    <div class="flex justify-center gap-2 mt-8">
      <div class="w-8 h-0.5 bg-navy-700"></div>
      <div class="w-8 h-0.5 bg-gray-300"></div>
      <div class="w-3 h-0.5 bg-gray-300"></div>
    </div>
  </div>
</section>

<!-- DESIGN YOUR RING CTA -->
<section class="py-24 bg-gradient-to-b from-blue-50 to-slate-100 relative overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <!-- Real ring image from Unsplash -->
    <div class="flex justify-center mb-8">
      <div class="w-40 h-40 relative">
        <div class="w-40 h-40 rounded-full overflow-hidden shadow-2xl border-4 border-white/50">
          <img src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=400&q=85&fit=crop&crop=center"
               alt="Custom engagement ring" class="w-full h-full object-cover">
        </div>
        <div class="absolute -top-2 -right-2 text-gold-400 text-2xl">✦</div>
        <div class="absolute -bottom-1 -left-1 text-gold-400 text-xl">✦</div>
      </div>
    </div>

    <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-4">Ring Creator</p>
    <h2 class="font-serif text-5xl md:text-6xl text-navy-800 mb-2">Design Your</h2>
    <div class="relative inline-block mb-6">
      <h2 class="font-serif text-5xl md:text-6xl italic text-navy-800">Engagement Ring</h2>
      <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gold-400 opacity-70"></div>
    </div>
    <p class="text-sm text-gray-600 max-w-lg mx-auto leading-relaxed mb-10">
      Design Your Engagement ring your way. Start with a ring setting &amp; then add the perfect center stone — or vice versa.
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/shop/collection/engagement-rings/" class="btn-outline">Begin with a Setting &rarr;</a>
      <a href="/shop/collection/lab-grown-diamonds/" class="btn-outline">Begin with a Stone &rarr;</a>
    </div>
  </div>
</section>

<!-- MnxStore COLLECTION — Category Grid -->
<section class="py-20 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-3">Shop by Category</p>
      <h2 class="font-serif text-4xl text-navy-800">{{ site_brand }} Collection</h2>
    </div>

    {% if categories %}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {% for cat in categories %}
      <a href="{{ url('products:collection', slug=cat.slug) }}"
         class="group relative overflow-hidden aspect-[4/5] bg-gray-100 hover:shadow-lg transition-shadow">
        {% if cat.image %}
          <img src="{{ cat.image.url }}" alt="{{ cat.name }}"
               class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
        {% else %}
          {# Use Unsplash images as fallback for category cards #}
          {% set cat_imgs = {
            'Engagement Rings': 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=800&q=80&fit=crop',
            'Toi Et Moi Rings': 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=800&q=80&fit=crop',
            'Lab-Grown Diamonds': 'https://images.unsplash.com/photo-1573408301185-9519f94533f0?w=800&q=80&fit=crop',
            'Necklaces': 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=800&q=80&fit=crop',
            'Earrings': 'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=800&q=80&fit=crop',
            'Bracelets': 'https://images.unsplash.com/photo-1573408301185-9519f94533f0?w=800&q=80&fit=crop',
          } %}
          {% set img_url = cat_imgs.get(cat.name, 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=800&q=80&fit=crop') %}
          <img src="{{ img_url }}" alt="{{ cat.name }}"
               class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
               loading="lazy">
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent group-hover:from-black/70 transition-all duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5">
          <h3 class="font-serif text-xl text-white mb-1">{{ cat.name }}</h3>
          <span class="text-xs tracking-wider text-white/70 uppercase">Shop Now &rarr;</span>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <!-- Static category cards with real Unsplash images -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {% for cat_name, img_url in [
        ('Engagement Rings', 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=800&q=80&fit=crop'),
        ('Toi Et Moi Rings', 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=800&q=80&fit=crop'),
        ('Lab-Grown Diamonds', 'https://images.unsplash.com/photo-1589308078059-be1415eab4c3?w=800&q=80&fit=crop'),
        ('Necklaces & Pendants', 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=800&q=80&fit=crop'),
        ('Earrings', 'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=800&q=80&fit=crop'),
        ('Bracelets & Bangles', 'https://images.unsplash.com/photo-1601121141461-9d6647bef0a1?w=800&q=80&fit=crop'),
      ] %}
      <a href="/shop/" class="group relative overflow-hidden aspect-[4/5] hover:shadow-lg transition-shadow">
        <img src="{{ img_url }}" alt="{{ cat_name }}"
             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
             loading="lazy">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent group-hover:from-black/70 transition-all duration-300"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5">
          <h3 class="font-serif text-xl text-white">{{ cat_name }}</h3>
          <span class="text-xs tracking-wider text-white/70 uppercase">Shop Now &rarr;</span>
        </div>
      </a>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>

<!-- FEATURED PRODUCTS — Carousel -->
<section class="py-20 page-bg">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-3">Handpicked for You</p>
      <h2 class="font-serif text-4xl text-navy-800">Featured Collection</h2>
      <p class="text-sm text-gray-500 mt-3 max-w-md mx-auto">Discover our most loved pieces, crafted with precision and passion.</p>
    </div>

    {% if featured_products %}
    <div x-data="{ startIdx: 0, perPage: 4, total: {{ featured_products|length }}, transition: false }"
         class="relative">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {% for product in featured_products[:8] %}
        <div>{{ product_card(product) }}</div>
        {% endfor %}
      </div>
      <div class="flex justify-center gap-2 mt-8">
        <div class="w-8 h-0.5 bg-navy-700"></div>
        <div class="w-8 h-0.5 bg-gray-300"></div>
        <div class="w-3 h-0.5 bg-gray-300"></div>
      </div>
    </div>
    {% else %}
    <!-- Empty state placeholder -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {% for i in range(4) %}
      <div class="animate-pulse">
        <div class="bg-gray-200 aspect-square mb-3"></div>
        <div class="h-3 bg-gray-200 rounded mb-2 w-3/4"></div>
        <div class="h-3 bg-gray-200 rounded w-1/2"></div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <div class="text-center mt-10">
      <a href="/shop/" class="btn-outline">Explore All Products &rarr;</a>
    </div>
  </div>
</section>

<!-- TOI ET MOI RINGS -->
{% if toi_et_moi %}
<section class="py-20 bg-gradient-to-b from-slate-100 to-blue-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-4">
      <h2 class="font-serif text-4xl text-navy-800">Toi et Moi Rings</h2>
      <p class="text-sm text-gray-500 mt-3 max-w-md mx-auto">Featuring two stones, these romantic rings are perfect for engagements or special moments.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mt-10">
      {% for product in toi_et_moi %}
      <div>{{ product_card(product) }}</div>
      {% endfor %}
    </div>

    <!-- Slider dots -->
    <div class="flex justify-center gap-2 mt-8">
      <div class="w-8 h-0.5 bg-navy-700"></div>
      <div class="w-12 h-0.5 bg-gray-300"></div>
    </div>

    <div class="text-center mt-8">
      <a href="/shop/collection/toi-et-moi/" class="btn-outline">Explore the Collection &rarr;</a>
    </div>
  </div>
</section>
{% endif %}

<!-- PROMO BANNER - Free Gift with real jewelry background -->
<section class="relative py-32 overflow-hidden">
  <!-- Real Unsplash diamond/jewelry background -->
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?w=1600&q=80&fit=crop&crop=center"
         alt="Diamond jewelry" class="w-full h-full object-cover" loading="lazy">
    <div class="absolute inset-0 bg-navy-900/80"></div>
  </div>
  <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center text-white">
    <p class="text-xs tracking-[0.3em] uppercase text-gold-400 mb-4">Limited Time Offer</p>
    <h2 class="font-serif text-4xl md:text-5xl italic mb-4">FREE Stud Earring on Purchase over $3000</h2>
    <p class="text-sm text-white/70 max-w-md mx-auto mb-8">Add any qualifying item to cart and receive a complimentary premium stud earring worth $700.</p>
    <a href="/shop/" class="btn-outline btn-outline-white">Shop Now &rarr;</a>
  </div>
</section>

<!-- WHY MNXSTORE -->
<section class="py-20 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-3">Why Choose Us</p>
      <h2 class="font-serif text-4xl text-navy-800">The {{ site_brand }} Promise</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {% for icon_path, title, desc in [
        ('M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4', 'Truly Custom', 'Every ring crafted exactly to your specifications with your choice of setting, stone, and metal.'),
        ('M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', 'IGI/GIA Certified', 'All our lab-grown diamonds come with internationally recognized certifications for guaranteed quality.'),
        ('M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064', 'Free Global Shipping', 'Enjoy complimentary insured shipping to anywhere in the world with full tracking and security.'),
      ] %}
      <div class="text-center">
        <div class="w-16 h-16 bg-cream-100 rounded-full flex items-center justify-center mx-auto mb-5 border border-gold-200">
          <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ icon_path }}"/></svg>
        </div>
        <h3 class="font-serif text-xl text-navy-800 mb-3">{{ title }}</h3>
        <p class="text-sm text-gray-500 leading-relaxed">{{ desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- NEW ARRIVALS -->
{% if new_arrivals %}
<section class="py-20 page-bg">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-2">Fresh Drops</p>
        <h2 class="font-serif text-4xl text-navy-800">New Arrivals</h2>
      </div>
      <a href="/shop/?sort=newest" class="btn-outline text-sm">View All &rarr;</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {% for product in new_arrivals %}
      <div>{{ product_card(product) }}</div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- TESTIMONIALS -->
<section class="py-20 bg-gradient-to-b from-navy-50 to-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold-600 mb-3">Happy Customers</p>
      <h2 class="font-serif text-4xl text-navy-800">What Our Customers Say</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for review, author, location in [
        ('"Absolutely stunning ring! The oval diamond is breathtaking. ' ~ site_brand ~ ' exceeded all my expectations and the customer service was fantastic."', 'Priya Sharma', 'Mumbai, India'),
        ('"I ordered a custom engagement ring and the whole team was incredibly helpful. The IGI certificate gave us such peace of mind. Will definitely be back!"', 'James Mitchell', 'London, UK'),
        ('"The quality is exceptional and shipping was fast and insured. The ring arrived beautifully packaged. My fiancée was in tears!"', 'Rahul Kapoor', 'Delhi, India'),
      ] %}
      <div class="bg-white p-7 border border-gray-100 shadow-sm">
        <!-- Stars -->
        <div class="flex items-center gap-1 mb-4 text-gold-400">
          {% for _ in range(5) %}★{% endfor %}
        </div>
        <p class="text-sm text-gray-600 leading-relaxed italic mb-5">{{ review }}</p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-navy-100 rounded-full flex items-center justify-center">
            <span class="text-sm font-semibold text-navy-700">{{ author[0] }}</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-navy-800">{{ author }}</p>
            <p class="text-xs text-gray-400">{{ location }}</p>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{% endblock %}
