{% extends "base.jinja" %}
{% from 'components/product_card.jinja' import product_card %}

{% block title %}{{ product.name }} — {{ site_brand }}{% endblock %}
{% block meta_description %}{{ product.short_description or product.description[:150] }}{% endblock %}

{% block content %}
<div class="bg-white min-h-screen">
  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 py-3">
    <div class="max-w-screen-xl mx-auto px-6">
      <nav class="flex items-center text-xs text-gray-500 space-x-1">
        <a href="{{ url('core:home') }}" class="hover:text-navy-700">Home</a>
        <span class="breadcrumb-dot"></span>
        <a href="{{ url('products:shop') }}" class="hover:text-navy-700">Shop</a>
        <span class="breadcrumb-dot"></span>
        <a href="{{ url('products:collection', slug=product.category.slug) }}" class="hover:text-navy-700">{{ product.category.name }}</a>
        <span class="breadcrumb-dot"></span>
        <span class="text-navy-800 font-medium line-clamp-1">{{ product.name[:40] }}...</span>
      </nav>
    </div>
  </div>

  <!-- Product Detail -->
  <div class="max-w-screen-xl mx-auto px-6 py-10 lg:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16"
         x-data="{ activeImage: 0 }">

      <!-- LEFT: Image Gallery -->
      <div class="space-y-4">
        <!-- Main Image -->
        <div class="aspect-square bg-gray-50 overflow-hidden">
          {% if images %}
            {% for img in images %}
            <img src="{{ img.image.url }}" alt="{{ img.alt or product.name }}"
                 class="w-full h-full object-cover"
                 x-show="activeImage === {{ loop.index0 }}"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100">
            {% endfor %}
          {% else %}
          <img src="{{ product.display_image_url }}" alt="{{ product.name }}"
               class="w-full h-full object-cover">
          {% endif %}
        </div>

        <!-- Thumbnails -->
        {% if images and images|length > 1 %}
        <div class="flex gap-3 overflow-x-auto pb-2">
          {% for img in images %}
          <button @click="activeImage = {{ loop.index0 }}"
                  :class="activeImage === {{ loop.index0 }} ? 'border-2 border-navy-700' : 'border border-gray-200 hover:border-gray-400'"
                  class="flex-shrink-0 w-16 h-16 overflow-hidden transition-all">
            <img src="{{ img.image.url }}" alt="{{ img.alt }}" class="w-full h-full object-cover">
          </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- RIGHT: Product Info -->
      <div class="flex flex-col">
        <!-- Category & Certification Badges -->
        <div class="flex items-center gap-2 mb-3">
          <a href="{{ url('products:collection', slug=product.category.slug) }}"
             class="text-xs tracking-widest uppercase text-gold-600 hover:text-gold-500 transition-colors">
            {{ product.category.name }}
          </a>
          {% if product.certification and product.certification != 'none' %}
          <span class="border border-navy-300 text-navy-700 text-xs px-2 py-0.5 font-medium uppercase">{{ product.certification }}</span>
          {% endif %}
        </div>

        <h1 class="font-serif text-2xl md:text-3xl text-navy-800 leading-snug mb-4">{{ product.name }}</h1>

        <!-- Price -->
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl font-medium text-gray-900">From Rs. {{ "{:,.2f}".format(product.price) }} INR</span>
          {% if product.compare_price %}
          <span class="text-base text-gray-400 line-through">Rs. {{ "{:,.2f}".format(product.compare_price) }}</span>
          <span class="bg-red-100 text-red-600 text-xs px-2 py-0.5 font-medium">-{{ product.discount_percent }}%</span>
          {% endif %}
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-100 mb-6"></div>

        {% if product.stock <= 0 %}
        <div class="border border-red-100 bg-red-50 text-red-700 text-sm px-4 py-3 mb-2">
          Out of stock — this piece is currently unavailable.
        </div>
        <button type="button" disabled class="btn-navy w-full py-4 text-sm opacity-50 cursor-not-allowed">
          Out of Stock
        </button>
        {% else %}
        <!-- Add to Cart Form -->
        <form hx-post="{{ url('cart:add', product_id=product.id) }}"
              hx-target="#cart-count"
              hx-swap="innerHTML"
              @htmx:after-request="if ($event.detail.successful) { cartOpen = true; $dispatch('cart-opened') }"
              class="space-y-5">
          {{ csrf_input(request) }}
          <input type="hidden" name="quantity" value="1">

          <!-- Metal selector -->
          {% if product.variants.all()|list %}
          <div>
            <label class="text-xs font-semibold tracking-widest uppercase text-gray-700 block mb-2">Metal Type</label>
            <div class="flex flex-wrap gap-2">
              {% set metals = [] %}
              {% for v in product.variants.all() %}
                {% if v.metal not in metals %}
                  {{ metals.append(v.metal) or '' }}
                  <label class="cursor-pointer">
                    <input type="radio" name="metal" value="{{ v.metal }}" class="sr-only peer" {% if loop.first %}checked{% endif %}>
                    <span class="peer-checked:border-navy-700 peer-checked:text-navy-700 peer-checked:bg-navy-50 border border-gray-200 px-3 py-1.5 text-xs font-medium tracking-wider text-gray-600 hover:border-gray-400 transition-all cursor-pointer">
                      {{ v.get_metal_display() }}
                    </span>
                  </label>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          {% else %}
          <!-- Default metal selector -->
          <div>
            <label class="text-xs font-semibold tracking-widest uppercase text-gray-700 block mb-2">Metal Type</label>
            <div class="flex flex-wrap gap-2">
              {% for metal_val, metal_label in [('yellow_gold', 'Yellow Gold'), ('white_gold', 'White Gold'), ('rose_gold', 'Rose Gold'), ('platinum', 'Platinum')] %}
              <label class="cursor-pointer">
                <input type="radio" name="metal" value="{{ metal_val }}" class="sr-only peer" {% if loop.first %}checked{% endif %}>
                <span class="peer-checked:border-navy-700 peer-checked:text-navy-700 peer-checked:bg-navy-50 border border-gray-200 px-3 py-1.5 text-xs font-medium tracking-wider text-gray-600 hover:border-gray-400 transition-all cursor-pointer">
                  {{ metal_label }}
                </span>
              </label>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          <!-- Ring size -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="text-xs font-semibold tracking-widest uppercase text-gray-700">Ring Size</label>
              <a href="#" class="text-xs text-gray-400 underline hover:text-navy-700">Size Guide</a>
            </div>
            <select name="ring_size" class="w-full border border-gray-200 px-3 py-2.5 text-sm text-gray-700 outline-none focus:border-navy-700 transition-colors bg-white">
              <option value="">Select a size</option>
              {% for size in ['4', '4.5', '5', '5.5', '6', '6.5', '7', '7.5', '8', '8.5', '9'] %}
              <option value="{{ size }}">{{ size }}</option>
              {% endfor %}
            </select>
          </div>

          <p class="text-xs text-gray-400">{{ product.stock }} in stock</p>

          <!-- Add to Cart -->
          <button type="submit" class="btn-navy w-full py-4 text-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            Add to Cart
          </button>
        </form>
        {% endif %}

        <!-- Trust badges -->
        <div class="grid grid-cols-3 gap-3 mt-6 pt-6 border-t border-gray-100">
          {% for icon_d, label in [
            ('M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', 'Certified'),
            ('M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064', 'Free Shipping'),
            ('M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', '30-Day Returns'),
          ] %}
          <div class="flex flex-col items-center text-center gap-1.5">
            <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ icon_d }}"/></svg>
            <span class="text-xs text-gray-500">{{ label }}</span>
          </div>
          {% endfor %}
        </div>

        <!-- Product Details Accordion -->
        <div class="mt-6 border-t border-gray-100 space-y-1">
          {% for tab, content in [
            ('Description', product.description or 'No description available.'),
            ('Details & Specs', (product.carat_weight and ('Carat Weight: ' + product.carat_weight|string + 'ct') or '') + (' | ' + product.get_certification_display() + ' Certified' if product.certification != 'none' else '')),
            ('Shipping & Returns', 'Free insured worldwide shipping. 30-day return policy. All pieces are carefully packaged.')
          ] %}
          <div x-data="{ open: {{ 'true' if loop.first else 'false' }} }" class="border-b border-gray-100">
            <button @click="open = !open"
                    class="w-full flex items-center justify-between py-4 text-left text-sm font-medium text-gray-700 hover:text-navy-700 transition-colors">
              {{ tab }}
              <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div x-show="open" x-collapse class="pb-4">
              <p class="text-sm text-gray-500 leading-relaxed">{{ content }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {% if related %}
    <div class="mt-20 pt-12 border-t border-gray-100">
      <div class="text-center mb-10">
        <h2 class="font-serif text-3xl text-navy-800">You May Also Like</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {% from 'components/product_card.jinja' import product_card %}
        {% for p in related %}
        <div>{{ product_card(p) }}</div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}
