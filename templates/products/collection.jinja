{% extends "base.jinja" %}
{% from 'components/product_card.jinja' import product_card %}

{% block title %}{{ category.name }} — {{ site_brand }}{% endblock %}
{% block meta_description %}Shop our {{ category.name }} collection — IGI/GIA certified lab-grown diamond jewelry. {{ category.description[:120] if category.description else '' }}{% endblock %}

{% block content %}
<div class="page-bg min-h-screen">

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-100 py-3">
    <div class="max-w-screen-xl mx-auto px-6">
      <nav class="flex items-center text-xs text-gray-500 space-x-1">
        <a href="{{ url('core:home') }}" class="hover:text-navy-700 transition-colors">Home</a>
        <span class="breadcrumb-dot"></span>
        <a href="{{ url('products:shop') }}" class="hover:text-navy-700 transition-colors">Shop</a>
        <span class="breadcrumb-dot"></span>
        <span class="text-navy-800 font-medium">{{ category.name }}</span>
      </nav>
    </div>
  </div>

  <!-- Collection Header -->
  <div class="bg-white py-12 border-b border-gray-100">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl text-navy-800 mb-4">{{ category.name }}</h1>
      {% if category.description %}
      <div x-data="{ expanded: false }">
        <p class="text-sm text-gray-500 max-w-2xl mx-auto leading-relaxed"
           :class="expanded ? '' : 'line-clamp-3'">{{ category.description }}</p>
        {% if category.description|length > 200 %}
        <button @click="expanded = !expanded"
                class="text-sm text-navy-700 underline underline-offset-2 mt-2">
          <span x-text="expanded ? 'Show less' : 'Show more'">Show more</span>
        </button>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>

  <!-- Products Section -->
  <div class="max-w-screen-xl mx-auto px-6 py-10">

    <!-- Controls Bar -->
    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      <!-- Grid toggle -->
      <div class="flex items-center gap-1" x-data="{ cols: 4 }">
        {% for n, icon in [(2, 'M4 6h16M4 12h16M4 18h16'), (3, 'M4 6h16M4 10h16M4 14h16M4 18h16'), (4, 'M3 5h3m12 0h3M3 10h3m12 0h3M3 15h3m12 0h3M3 20h3m12 0h3')] %}
        <button @click="cols = {{ n }}" :class="cols === {{ n }} ? 'bg-navy-700 text-white' : 'text-gray-400 hover:text-navy-700 hover:bg-gray-100'"
                class="p-1.5 border border-gray-200 transition-all"
                x-data>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ icon }}"/></svg>
        </button>
        {% endfor %}
        <span class="ml-3 text-sm text-gray-500">{{ product_count }} products</span>
      </div>

      <!-- Sort dropdown -->
      <div class="flex items-center gap-3">
        <label class="text-xs text-gray-500 tracking-wider uppercase whitespace-nowrap">Sort by:</label>
        <form id="sort-form">
          <select name="sort" onchange="this.form.submit()"
                  class="border border-gray-200 text-sm px-3 py-2 pr-8 outline-none bg-white text-gray-700 cursor-pointer focus:border-navy-700">
            <option value="newest" {% if sort == 'newest' %}selected{% endif %}>Newest</option>
            <option value="az" {% if sort == 'az' %}selected{% endif %}>Alphabetically, A–Z</option>
            <option value="za" {% if sort == 'za' %}selected{% endif %}>Alphabetically, Z–A</option>
            <option value="price_asc" {% if sort == 'price_asc' %}selected{% endif %}>Price: Low to High</option>
            <option value="price_desc" {% if sort == 'price_desc' %}selected{% endif %}>Price: High to Low</option>
          </select>
        </form>
      </div>
    </div>

    <!-- Product Grid -->
    {% if products %}
    <div x-data="{ cols: 4 }">
      <div :class="{
        'grid-cols-2 md:grid-cols-2': cols === 2,
        'grid-cols-2 md:grid-cols-3': cols === 3,
        'grid-cols-2 md:grid-cols-4': cols === 4,
      }" class="grid gap-4 md:gap-6">
        {% for product in products %}
        <div>{{ product_card(product) }}</div>
        {% endfor %}
      </div>
    </div>
    {% else %}
    <div class="text-center py-24">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      <h3 class="text-lg font-serif text-gray-400 mb-2">No products found</h3>
      <p class="text-sm text-gray-400 mb-6">This collection is being curated. Check back soon!</p>
      <a href="{{ url('products:shop') }}" class="btn-outline">Browse All Products &rarr;</a>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}
