<!DOCTYPE html>
<html lang="en" x-data="{ cartOpen: false, searchOpen: false, navMobile: false }">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site_settings.site_name }} — {{ site_tagline }}{% endblock %}</title>
  {% if site_settings.logo %}<link rel="icon" href="{{ site_settings.logo.url }}">{% endif %}
  <meta name="description" content="{% block meta_description %}Shop IGI & GIA certified lab-grown diamond engagement rings, jewelry, and more. Custom designs shipped worldwide.{% endblock %}">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: { 50: '#f0f1f8', 100: '#d9daf0', 200: '#b3b5e1', 300: '#8d90d2', 400: '#6769c2', 500: '#4142b3', 600: '#2d2e9e', 700: '#1a1b5e', 800: '#131447', 900: '#0c0d2f' },
            gold: { 300: '#e4c97e', 400: '#d4b05f', 500: '#c5a55a', 600: '#a8853a', 700: '#8b6520' },
            cream: { 50: '#fafaf9', 100: '#f5f5f3', 200: '#eeecea', 300: '#e2dfdb' },
          },
          fontFamily: {
            serif: ['"Playfair Display"', 'Georgia', 'serif'],
            sans: ['Inter', 'system-ui', 'sans-serif'],
            italic: ['"Cormorant Garamond"', 'serif'],
          },
        }
      }
    }
  </script>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <!-- HTMX -->
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>

  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-serif { font-family: 'Playfair Display', Georgia, serif; }
    .font-italic { font-family: 'Cormorant Garamond', serif; }
    .announcement-bar { background: #1a1b5e; }
    .gold-underline { border-bottom: 2px solid #c5a55a; }
    .product-card:hover .product-img { transform: scale(1.05); }
    .product-img { transition: transform 0.5s ease; }
    /* Cart drawer */
    [x-cloak] { display: none !important; }
    .cart-drawer { transition: transform 0.3s ease; }
    /* Page bg */
    .page-bg { background-color: #f3f4f8; }
    /* Gold accent text */
    .text-gold { color: #c5a55a; }
    .bg-navy { background-color: #1a1b5e; }
    /* Thin scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #c5a55a; border-radius: 2px; }
    /* Smooth transitions */
    * { scroll-behavior: smooth; }
    /* Form inputs */
    .form-input { width: 100%; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: 0; font-size: 0.9rem; outline: none; transition: border-color 0.2s; background: white; }
    .form-input:focus { border-color: #1a1b5e; }
    /* Outline button */
    .btn-outline { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 2rem; border: 1px solid #1a1b5e; color: #1a1b5e; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: all 0.2s; background: transparent; cursor: pointer; }
    .btn-outline:hover { background: #1a1b5e; color: white; }
    .btn-outline-white { border-color: white; color: white; }
    .btn-outline-white:hover { background: white; color: #1a1b5e; }
    .btn-navy { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.875rem 2.5rem; background: #1a1b5e; color: white; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: all 0.2s; cursor: pointer; border: 1px solid #1a1b5e; }
    .btn-navy:hover { background: #131447; }
    /* Mega menu */
    .mega-menu { opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.2s ease; }
    .nav-item:hover .mega-menu { opacity: 1; visibility: visible; transform: translateY(0); }
    /* Breadcrumb */
    .breadcrumb-dot::before { content: "◆"; margin: 0 0.5rem; color: #c5a55a; font-size: 0.5rem; vertical-align: middle; }
  </style>
  {% block extra_head %}{% endblock %}
</head>

<body class="bg-white text-gray-900"
      x-init="
        document.body.addEventListener('htmx:configRequest', (e) => {
          const cookie = document.cookie.split(';').find(c => c.trim().startsWith('csrftoken='));
          if (cookie) e.detail.headers['X-CSRFToken'] = cookie.split('=')[1];
        });
      ">

<!-- Announcement Bar -->
{% include 'components/announcement_bar.jinja' %}

<!-- Navbar -->
{% include 'components/navbar.jinja' %}

<!-- Cart Drawer Overlay -->
<div x-cloak x-show="cartOpen" class="fixed inset-0 z-50 flex">
  <div @click="cartOpen = false" class="flex-1 bg-black/40 backdrop-blur-sm"></div>
  <div class="w-full max-w-md bg-white shadow-2xl flex flex-col cart-drawer"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full"
       x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-300"
       x-transition:leave-start="translate-x-0"
       x-transition:leave-end="translate-x-full">
    <div id="cart-drawer" hx-get="{{ url('cart:drawer') }}" hx-trigger="load" hx-swap="innerHTML" class="flex flex-col h-full">
      <div class="flex items-center justify-between p-6 border-b">
        <h2 class="font-serif text-xl">Your Cart</h2>
        <button @click="cartOpen = false" class="text-gray-400 hover:text-gray-900">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-6">
        <p class="text-gray-500 text-sm">Loading cart...</p>
      </div>
    </div>
  </div>
</div>

<!-- Search Overlay -->
<div x-cloak x-show="searchOpen" class="fixed inset-0 z-50 bg-white/98 backdrop-blur-md flex items-start pt-24"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">
  <div class="w-full max-w-3xl mx-auto px-6">
    <button @click="searchOpen = false" class="absolute top-8 right-8 text-gray-400 hover:text-gray-900">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <form action="{{ url('products:search') }}" method="GET" class="flex items-center border-b-2 border-navy-700 pb-4">
      <svg class="w-6 h-6 text-navy-700 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" name="q" placeholder="Search for rings, diamonds, jewelry..." autofocus
             class="flex-1 text-xl text-navy-700 placeholder-gray-400 bg-transparent outline-none font-light">
      <button type="submit" class="text-navy-700">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </button>
    </form>
    <p class="text-sm text-gray-400 mt-4">Popular searches: engagement ring, oval diamond, toi et moi, yellow gold</p>
  </div>
</div>

<!-- Newsletter Popup (Alpine.js: show once per session) -->
{% include 'components/newsletter_popup.jinja' %}

<!-- Flash Messages -->
{% with messages = get_messages(request) %}
  {% if messages %}
    <div class="fixed top-20 right-4 z-40 space-y-2" id="flash-messages">
      {% for message in messages %}
        <div class="bg-white border border-gray-200 shadow-lg px-4 py-3 text-sm flex items-center gap-3 max-w-xs"
             x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 4000)"
             x-transition:leave="transition ease-in duration-300" x-transition:leave-end="opacity-0 translate-x-4">
          {% if message.tags == 'error' %}
            <span class="text-red-500">✕</span>
          {% else %}
            <span class="text-green-500">✓</span>
          {% endif %}
          <span class="text-gray-700">{{ message }}</span>
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}

<!-- Main Content -->
<main>
  {% block content %}{% endblock %}
</main>

<!-- Footer -->
{% include 'components/footer.jinja' %}

{% block extra_js %}{% endblock %}
</body>
</html>
