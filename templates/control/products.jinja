{% extends "control/base_control.jinja" %}

{% block title %}Products{% endblock %}
{% block page_title %}Products{% endblock %}
{% block page_subtitle %}{{ products|length }} products{% endblock %}

{% block topbar_actions %}
<a href="{{ url('control:product_create') }}" class="ctrl-btn ctrl-btn-gold">
  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
  Add Product
</a>
{% endblock %}

{% block content %}
<div class="ctrl-card p-4 mb-4">
  <input type="text" name="q" value="{{ q }}"
         placeholder="Search products..."
         hx-get="{{ url('control:products') }}"
         hx-target="#product-rows"
         hx-trigger="keyup changed delay:300ms"
         hx-include="[name='q']"
         class="ctrl-input max-w-sm">
</div>

<div class="ctrl-card overflow-hidden">
  <table class="w-full text-xs">
    <thead class="border-b border-gray-700">
      <tr class="text-gray-500">
        <th class="text-left px-4 py-3 font-medium">Product</th>
        <th class="text-left px-4 py-3 font-medium">Category</th>
        <th class="text-left px-4 py-3 font-medium">Price</th>
        <th class="text-left px-4 py-3 font-medium">Stock</th>
        <th class="text-left px-4 py-3 font-medium">Status</th>
        <th class="text-left px-4 py-3 font-medium">Actions</th>
      </tr>
    </thead>
    <tbody id="product-rows" class="divide-y divide-gray-800">
      {% include "control/partials/_product_rows.jinja" %}
    </tbody>
  </table>
</div>
{% endblock %}
