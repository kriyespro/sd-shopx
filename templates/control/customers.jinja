{% extends "control/base_control.jinja" %}
{% block title %}Customers{% endblock %}
{% block page_title %}Customers{% endblock %}
{% block page_subtitle %}All buyers with order history{% endblock %}

{% block content %}
<div class="ctrl-card p-4 mb-4">
  <input type="text"
         placeholder="Search by name or email…"
         value="{{ q }}"
         hx-get="{{ url('control:customers') }}"
         hx-target="#customer-table"
         hx-trigger="keyup changed delay:300ms"
         name="q"
         class="ctrl-input max-w-sm">
</div>

<div class="ctrl-card overflow-hidden">
  <table class="w-full text-sm" id="customer-table">
    <thead class="border-b border-gray-800">
      <tr class="text-left text-xs text-gray-500 uppercase tracking-wider">
        <th class="px-4 py-3">Customer</th>
        <th class="px-4 py-3">Email</th>
        <th class="px-4 py-3 text-right">Orders</th>
        <th class="px-4 py-3 text-right">Lifetime Value</th>
        <th class="px-4 py-3">Joined</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800/60" id="customer-rows">
      {% for customer in customers %}
      <tr class="hover:bg-white/5 transition-colors">
        <td class="px-4 py-3">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-navy-700 flex items-center justify-center text-xs font-bold text-white">
              {{ (customer.first_name[0] if customer.first_name else customer.email[0]).upper() }}
            </div>
            <span class="text-gray-200 font-medium">{{ customer.get_full_name() or customer.username }}</span>
          </div>
        </td>
        <td class="px-4 py-3 text-gray-400">{{ customer.email }}</td>
        <td class="px-4 py-3 text-right text-gray-300">{{ customer.order_count }}</td>
        <td class="px-4 py-3 text-right font-medium text-gold-400">
          ₹{{ "%.0f"|format(customer.lifetime_value or 0) }}
        </td>
        <td class="px-4 py-3 text-gray-500 text-xs">{{ customer.date_joined.strftime('%d %b %Y') }}</td>
        <td class="px-4 py-3 text-right">
          <a href="{{ url('control:customer_detail', pk=customer.pk) }}"
             class="ctrl-btn ctrl-btn-gray text-xs">View</a>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-4 py-12 text-center text-gray-500">No customers found.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
