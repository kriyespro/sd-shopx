<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mission Control Login — {{ site_brand }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: { 400: '#d4b05f', 500: '#c5a55a' },
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="w-12 h-12 bg-gold-500 rounded flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
      </div>
      <h1 class="text-xl font-semibold text-white">Mission Control</h1>
      <p class="text-xs text-gray-500 mt-1">Staff access only — Superuser & Store Manager</p>
    </div>

    {% with messages = get_messages(request) %}
    {% if messages %}
    <div class="mb-4 space-y-2">
      {% for message in messages %}
      <div class="px-4 py-2.5 rounded text-sm bg-red-900/50 text-red-300 border border-red-800">{{ message }}</div>
      {% endfor %}
    </div>
    {% endif %}
    {% endwith %}

    <form method="post" class="bg-[#1a1d2e] border border-gray-800 rounded-lg p-6 space-y-4">
      {{ csrf_input(request) }}
      {% if request.GET.next %}
      <input type="hidden" name="next" value="{{ request.GET.next }}">
      {% endif %}
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1 uppercase tracking-wider">Email or Username</label>
        <input type="text" name="email" value="{{ email or '' }}" required autofocus
               class="w-full px-3 py-2.5 bg-gray-900 border border-gray-700 rounded text-sm text-white outline-none focus:border-gold-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1 uppercase tracking-wider">Password</label>
        <input type="password" name="password" required
               class="w-full px-3 py-2.5 bg-gray-900 border border-gray-700 rounded text-sm text-white outline-none focus:border-gold-500">
      </div>
      <button type="submit" class="w-full py-2.5 bg-gold-500 text-[#0f1023] text-sm font-semibold rounded hover:bg-gold-400 transition-colors">
        Sign In
      </button>
    </form>
    <p class="text-center text-xs text-gray-600 mt-6">
      <a href="/" class="hover:text-gray-400">← Back to store</a>
    </p>
  </div>
</body>
</html>
