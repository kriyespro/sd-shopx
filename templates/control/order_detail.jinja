{% extends "control/base_control.jinja" %}

{% block title %}Order #{{ order.order_number }}{% endblock %}
{% block page_title %}Order #{{ order.order_number }}{% endblock %}
{% block page_subtitle %}{{ order.created_at.strftime('%B %d, %Y at %H:%M') }}{% endblock %}

{% block topbar_actions %}
<a href="{{ url('control:orders') }}" class="ctrl-btn ctrl-btn-gray">← Back</a>
{% endblock %}

{% block content %}
{% set sc = {
  'pending': 'bg-yellow-900/50 text-yellow-300',
  'confirmed': 'bg-blue-900/50 text-blue-300',
  'processing': 'bg-purple-900/50 text-purple-300',
  'shipped': 'bg-cyan-900/50 text-cyan-300',
  'delivered': 'bg-green-900/50 text-green-300',
  'cancelled': 'bg-red-900/50 text-red-300',
  'refunded': 'bg-gray-700 text-gray-400'
} %}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- LEFT: Items + Address + Payment + Refunds -->
  <div class="lg:col-span-2 space-y-4">

    <!-- Items -->
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-4">Items</h3>
      <table class="w-full text-xs">
        <thead class="border-b border-gray-700">
          <tr class="text-gray-500">
            <th class="text-left pb-2 font-medium">Product</th>
            <th class="text-left pb-2 font-medium">Metal / Size</th>
            <th class="text-left pb-2 font-medium">Price</th>
            <th class="text-left pb-2 font-medium">Qty</th>
            <th class="text-right pb-2 font-medium">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          {% for item in order.items.all() %}
          <tr>
            <td class="py-2.5 text-gray-300">{{ item.product_name }}</td>
            <td class="py-2.5 text-gray-500">{{ item.metal_type or '—' }} {{ item.ring_size or '' }}</td>
            <td class="py-2.5 text-gray-300">₹{{ item.price }}</td>
            <td class="py-2.5 text-gray-400">{{ item.quantity }}</td>
            <td class="py-2.5 text-gray-200 text-right font-medium">₹{{ item.total_price }}</td>
          </tr>
          {% endfor %}
        </tbody>
        <tfoot class="border-t border-gray-700">
          <tr>
            <td colspan="4" class="pt-3 text-right text-xs text-gray-500">Subtotal</td>
            <td class="pt-3 text-right text-gray-300">₹{{ order.subtotal }}</td>
          </tr>
          <tr>
            <td colspan="4" class="pt-1 text-right text-xs text-gray-500">Shipping</td>
            <td class="pt-1 text-right text-gray-300">₹{{ order.shipping_cost }}</td>
          </tr>
          <tr>
            <td colspan="4" class="pt-2 text-right text-sm font-semibold text-gray-200">Total</td>
            <td class="pt-2 text-right text-base font-bold text-white">₹{{ order.total }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Shipping Address -->
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-3">Shipping Address</h3>
      <div class="text-xs text-gray-400 space-y-1">
        <p class="text-gray-200 font-medium">{{ order.first_name }} {{ order.last_name }}</p>
        <p>{{ order.email }}</p>
        {% if order.phone %}<p>{{ order.phone }}</p>{% endif %}
        <p>{{ order.address_line1 }}{% if order.address_line2 %}, {{ order.address_line2 }}{% endif %}</p>
        <p>{{ order.city }}, {{ order.state }} {{ order.pincode }}</p>
        <p>{{ order.country }}</p>
      </div>
    </div>

    <!-- Payment Details -->
    <div class="ctrl-card p-5" x-data="{ open: {{ 'true' if not payment else 'false' }} }">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-200">Payment Details</h3>
        {% if payment %}
        <div class="flex items-center gap-2">
          <span class="badge {% if payment.status == 'paid' %}bg-green-900/50 text-green-300{% elif payment.status == 'failed' %}bg-red-900/50 text-red-300{% else %}bg-yellow-900/50 text-yellow-300{% endif %} text-[10px]">
            {{ payment.get_status_display() }}
          </span>
          <span class="text-white font-semibold text-sm">₹{{ payment.amount }}</span>
          <button @click="open = !open" class="ctrl-btn ctrl-btn-gray text-xs">Edit</button>
        </div>
        {% endif %}
      </div>

      {% if payment and not True %}{% endif %}
      {% if payment %}
      <div class="grid grid-cols-2 gap-3 text-xs mb-4" x-show="!open">
        <div><span class="text-gray-500">Method</span><p class="text-gray-300 mt-0.5">{{ payment.get_method_display() }}</p></div>
        <div><span class="text-gray-500">Gateway</span><p class="text-gray-300 mt-0.5">{{ payment.gateway or '—' }}</p></div>
        <div><span class="text-gray-500">Transaction ID</span><p class="text-gray-300 mt-0.5 font-mono">{{ payment.transaction_id or '—' }}</p></div>
        <div><span class="text-gray-500">Paid At</span><p class="text-gray-300 mt-0.5">{{ payment.paid_at.strftime('%d %b %Y %H:%M') if payment.paid_at else '—' }}</p></div>
      </div>
      {% endif %}

      <form method="post" action="{{ url('control:payment_save', order_pk=order.pk) }}"
            class="space-y-3" x-show="open">
        {{ csrf_input }}
        <div class="grid grid-cols-2 gap-3">
          <div><label class="ctrl-label">Method</label>{{ payment_form.method }}</div>
          <div><label class="ctrl-label">Status</label>{{ payment_form.status }}</div>
          <div><label class="ctrl-label">Amount</label>{{ payment_form.amount }}</div>
          <div><label class="ctrl-label">Gateway</label>{{ payment_form.gateway }}</div>
          <div class="col-span-2"><label class="ctrl-label">Transaction ID</label>{{ payment_form.transaction_id }}</div>
          <div class="col-span-2"><label class="ctrl-label">Paid At</label>{{ payment_form.paid_at }}</div>
        </div>
        <button type="submit" class="ctrl-btn ctrl-btn-gold">Save Payment</button>
      </form>
    </div>

    <!-- Refunds -->
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-4">Refunds</h3>
      {% if refunds %}
      <div class="space-y-3 mb-4">
        {% for refund in refunds %}
        {% set ref_colors = {
          'requested': 'bg-yellow-900/50 text-yellow-300',
          'approved': 'bg-blue-900/50 text-blue-300',
          'processing': 'bg-purple-900/50 text-purple-300',
          'processed': 'bg-green-900/50 text-green-300',
          'rejected': 'bg-red-900/50 text-red-300',
        } %}
        <div class="flex items-center justify-between bg-gray-800/40 rounded p-3">
          <div class="text-xs">
            <p class="text-gray-200 font-medium">₹{{ refund.amount }} — {{ refund.reason[:60] ~ '…' if refund.reason|length > 60 else refund.reason }}</p>
            <p class="text-gray-500 mt-0.5">{{ refund.requested_at.strftime('%d %b %Y') }}</p>
          </div>
          <div class="flex items-center gap-2">
            <span class="badge {{ ref_colors.get(refund.status, 'bg-gray-700 text-gray-300') }} text-[10px]">{{ refund.get_status_display() }}</span>
            <a href="{{ url('control:refund_detail', pk=refund.pk) }}" class="ctrl-btn ctrl-btn-gray text-xs">Manage</a>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      <!-- Create refund -->
      <details class="group">
        <summary class="ctrl-btn ctrl-btn-gray text-xs cursor-pointer list-none">+ Create Refund</summary>
        <form method="post" action="{{ url('control:refund_create', order_pk=order.pk) }}"
              class="mt-3 space-y-3 border-t border-gray-800 pt-3">
          {{ csrf_input }}
          <div><label class="ctrl-label">Refund Amount</label>{{ refund_form.amount }}</div>
          <div><label class="ctrl-label">Reason</label>{{ refund_form.reason }}</div>
          <div><label class="ctrl-label">Internal Notes</label>{{ refund_form.notes }}</div>
          <button type="submit" class="ctrl-btn ctrl-btn-red">Submit Refund</button>
        </form>
      </details>
    </div>
  </div>

  <!-- RIGHT: Status + Customer -->
  <div class="space-y-4">
    <div class="ctrl-card p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-200">Order Status</h3>
        <span class="badge {{ sc.get(order.status, 'bg-gray-700 text-gray-300') }} text-xs">{{ order.get_status_display() }}</span>
      </div>
      <form method="post" class="space-y-4">
        {{ csrf_input }}
        <div>
          <label class="ctrl-label">Update Status</label>
          {{ form.status }}
        </div>
        <div>
          <label class="ctrl-label">Notes</label>
          {{ form.notes }}
        </div>
        <button type="submit" class="ctrl-btn ctrl-btn-gold w-full justify-center">Update Order</button>
      </form>
    </div>

    <!-- Customer -->
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-3">Customer</h3>
      {% if order.user %}
      <a href="{{ url('control:customer_detail', pk=order.user.pk) }}"
         class="flex items-center gap-3 hover:bg-gray-800/30 rounded p-1 -m-1 transition-colors">
        <div class="w-8 h-8 rounded-full bg-navy-700 flex items-center justify-center text-xs font-bold text-white">
          {{ order.user.first_name[0] if order.user.first_name else order.user.username[0] }}
        </div>
        <div>
          <p class="text-xs font-medium text-gray-200">{{ order.user.get_full_name() or order.user.username }}</p>
          <p class="text-xs text-gold-400">View profile →</p>
        </div>
      </a>
      {% else %}
      <p class="text-xs text-gray-500">Guest order — {{ order.email }}</p>
      {% endif %}
    </div>

    <!-- Timeline -->
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-3">Timeline</h3>
      <div class="space-y-2 text-xs">
        <div class="flex justify-between"><span class="text-gray-500">Placed</span><span class="text-gray-300">{{ order.created_at.strftime('%d %b %Y %H:%M') }}</span></div>
        <div class="flex justify-between"><span class="text-gray-500">Last Updated</span><span class="text-gray-300">{{ order.updated_at.strftime('%d %b %Y %H:%M') }}</span></div>
        {% if payment and payment.paid_at %}
        <div class="flex justify-between"><span class="text-gray-500">Paid At</span><span class="text-green-400">{{ payment.paid_at.strftime('%d %b %Y %H:%M') }}</span></div>
        {% endif %}
      </div>
    </div>

    {% if order.notes %}
    <div class="ctrl-card p-5">
      <h3 class="text-sm font-semibold text-gray-200 mb-2">Notes</h3>
      <p class="text-xs text-gray-400">{{ order.notes }}</p>
    </div>
    {% endif %}
  </div>

</div>
{% endblock %}
