<!DOCTYPE html>
<html lang="en" x-data="{ sidebarOpen: true, mobileNav: false }">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Mission Control{% endblock %} — {{ site_brand }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: { 50: '#f0f1f8', 100: '#d9daf0', 700: '#1a1b5e', 800: '#131447', 900: '#0c0d2f' },
            gold: { 400: '#d4b05f', 500: '#c5a55a' },
            sidebar: '#0f1023',
          }
        }
      }
    }
  </script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    [x-cloak] { display: none !important; }
    .ctrl-input { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #374151; border-radius: 0.375rem; background: #1f2937; color: #f9fafb; font-size: 0.875rem; outline: none; }
    .ctrl-input:focus { border-color: #c5a55a; }
    .ctrl-select { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #374151; border-radius: 0.375rem; background: #1f2937; color: #f9fafb; font-size: 0.875rem; outline: none; }
    .ctrl-select:focus { border-color: #c5a55a; }
    .ctrl-label { display: block; font-size: 0.75rem; font-weight: 500; color: #9ca3af; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .ctrl-btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; font-size: 0.8rem; font-weight: 500; border-radius: 0.375rem; cursor: pointer; transition: all 0.15s; }
    .ctrl-btn-gold { background: #c5a55a; color: #0f1023; }
    .ctrl-btn-gold:hover { background: #d4b05f; }
    .ctrl-btn-red { background: #dc2626; color: white; }
    .ctrl-btn-red:hover { background: #b91c1c; }
    .ctrl-btn-gray { background: #374151; color: #d1d5db; }
    .ctrl-btn-gray:hover { background: #4b5563; }
    .ctrl-card { background: #1a1d2e; border: 1px solid #2d3148; border-radius: 0.5rem; }
    .nav-link { display: flex; align-items: center; gap: 0.625rem; padding: 0.625rem 1rem; font-size: 0.8rem; color: #9ca3af; border-radius: 0.375rem; transition: all 0.15s; text-decoration: none; }
    .nav-link:hover, .nav-link.active { background: #1a1d2e; color: #f9fafb; }
    .nav-link.active { color: #c5a55a; }
    .badge { display: inline-flex; align-items: center; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 600; }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen flex">
{% set current = request.resolver_match.url_name if request.resolver_match else '' %}

{# Shared sidebar nav markup #}
{% macro control_nav(close_mobile=false) %}
  <a href="{{ url('control:dashboard') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if current == 'dashboard' %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM14 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zM14 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/></svg>
    <span class="whitespace-nowrap">Dashboard</span>
  </a>

  <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-600 uppercase tracking-widest">Catalog</p>

  <a href="{{ url('control:products') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'product' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
    <span class="whitespace-nowrap">Products</span>
  </a>

  <a href="{{ url('control:categories') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'categor' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
    <span class="whitespace-nowrap">Categories</span>
  </a>

  <a href="{{ url('control:inventory') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'inventory' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
    <span class="whitespace-nowrap">Inventory</span>
  </a>

  <a href="{{ url('control:reviews') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'review' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
    <span class="whitespace-nowrap">Reviews</span>
  </a>

  <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-600 uppercase tracking-widest">Commerce</p>

  <a href="{{ url('control:orders') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if current == 'orders' or current == 'order_detail' %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    <span class="whitespace-nowrap">Orders</span>
  </a>

  <a href="{{ url('control:payments') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'payment' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
    <span class="whitespace-nowrap">Payments</span>
  </a>

  <a href="{{ url('control:refunds') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'refund' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
    <span class="whitespace-nowrap">Refunds</span>
  </a>

  <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-600 uppercase tracking-widest">People</p>

  <a href="{{ url('control:customers') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if 'customer' in current %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    <span class="whitespace-nowrap">Customers</span>
  </a>

  {% if is_control_superuser %}
  <a href="{{ url('control:users') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if current == 'users' or current == 'user_detail' %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
    <span class="whitespace-nowrap">Staff / Users</span>
  </a>

  <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-600 uppercase tracking-widest">System</p>

  <a href="{{ url('control:activity') }}"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link {% if current == 'activity' %}active{% endif %}">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span class="whitespace-nowrap">Activity Log</span>
  </a>

  <a href="/sd/core/sitesettings/"
     {% if close_mobile %}@click="mobileNav = false"{% endif %}
     class="nav-link">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    <span class="whitespace-nowrap">Site Settings</span>
  </a>
  {% endif %}
{% endmacro %}

<!-- Desktop Sidebar -->
<aside class="hidden lg:flex flex-col bg-[#0f1023] border-r border-gray-800 fixed inset-y-0 left-0 z-30"
       :class="sidebarOpen ? 'w-56' : 'w-14'" style="transition: width 0.2s ease;">

  <div class="flex items-center gap-2 px-4 py-5 border-b border-gray-800">
    <img src="{{ default_site_mark }}" alt="{{ site_brand }}" class="w-8 h-8 object-contain flex-shrink-0 bg-white rounded p-0.5">
    <span class="font-semibold text-sm text-white whitespace-nowrap overflow-hidden" x-show="sidebarOpen" x-cloak>Mission Control</span>
  </div>

  <nav class="flex-1 px-2 py-4 space-y-0.5 overflow-y-auto">
    {{ control_nav() }}
  </nav>

  <div class="border-t border-gray-800 p-3 flex items-center justify-between gap-2">
    <div class="flex items-center gap-2 overflow-hidden min-w-0" x-show="sidebarOpen" x-cloak>
      <div class="w-7 h-7 rounded-full bg-navy-700 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">
        {{ request.user.first_name[0] if request.user.first_name else request.user.username[0] }}
      </div>
      <div class="overflow-hidden min-w-0">
        <p class="text-xs font-medium text-gray-200 truncate">{{ request.user.get_full_name() or request.user.username }}</p>
        <p class="text-xs text-gold-400">{{ control_role_label }}</p>
      </div>
    </div>
    <button type="button" @click="sidebarOpen = !sidebarOpen" class="text-gray-500 hover:text-gray-200 p-1" title="Toggle sidebar">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <a href="{{ url('control:logout') }}" class="text-gray-500 hover:text-red-400 transition-colors" title="Sign out">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
    </a>
  </div>
</aside>

<!-- Mobile nav overlay -->
<div x-cloak x-show="mobileNav" class="lg:hidden fixed inset-0 z-40 flex">
  <div class="absolute inset-0 bg-black/60" @click="mobileNav = false"></div>
  <aside class="relative w-64 max-w-[85vw] bg-[#0f1023] border-r border-gray-800 flex flex-col h-full shadow-2xl"
         x-show="mobileNav"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="-translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="-translate-x-full">
    <div class="flex items-center justify-between px-4 py-4 border-b border-gray-800">
      <div class="flex items-center gap-2">
        <img src="{{ default_site_mark }}" alt="{{ site_brand }}" class="w-8 h-8 object-contain bg-white rounded p-0.5">
        <span class="font-semibold text-sm text-white">Mission Control</span>
      </div>
      <button type="button" @click="mobileNav = false" class="text-gray-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex-1 px-2 py-4 space-y-0.5 overflow-y-auto">
      {{ control_nav(close_mobile=true) }}
    </nav>
    <div class="border-t border-gray-800 p-4 flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-200">{{ request.user.get_full_name() or request.user.username }}</p>
        <p class="text-xs text-gold-400">{{ control_role_label }}</p>
      </div>
      <a href="{{ url('control:logout') }}" class="text-sm text-red-400 hover:text-red-300">Sign out</a>
    </div>
  </aside>
</div>

<!-- Main -->
<div class="flex-1 w-full min-w-0 flex flex-col min-h-screen lg:ml-56"
     :class="sidebarOpen ? 'lg:ml-56' : 'lg:ml-14'"
     style="transition: margin-left 0.2s ease;">

  <!-- Topbar -->
  <header class="bg-[#0f1023] border-b border-gray-800 px-4 sm:px-6 py-3 flex items-center justify-between sticky top-0 z-20 gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <button type="button" @click="mobileNav = true"
              class="lg:hidden p-2 -ml-1 rounded text-gray-300 hover:bg-gray-800 hover:text-white"
              aria-label="Open menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div class="min-w-0">
        <h1 class="text-base font-semibold text-white truncate">{% block page_title %}Dashboard{% endblock %}</h1>
        <p class="text-xs text-gray-500 truncate">{% block page_subtitle %}{% endblock %}</p>
      </div>
    </div>
    <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
      <span class="badge bg-gold-500/20 text-gold-400 hidden sm:inline-flex">{{ control_role_label }}</span>
      {% block topbar_actions %}{% endblock %}
      <a href="/" target="_blank" class="ctrl-btn ctrl-btn-gray text-xs">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <span class="hidden sm:inline">View Site</span>
      </a>
    </div>
  </header>

  <!-- Flash Messages -->
  {% with messages = get_messages(request) %}
  {% if messages %}
  <div class="px-4 sm:px-6 pt-4 space-y-2">
    {% for message in messages %}
    <div class="flex items-center gap-2 px-4 py-2.5 rounded text-sm
                {% if message.tags == 'error' %}bg-red-900/50 text-red-300 border border-red-800
                {% else %}bg-green-900/50 text-green-300 border border-green-800{% endif %}"
         x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 4000)">
      <span>{{ message }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% endwith %}

  <!-- Content -->
  <main class="flex-1 p-4 sm:p-6">
    {% block content %}{% endblock %}
  </main>

</div>

</body>
</html>
