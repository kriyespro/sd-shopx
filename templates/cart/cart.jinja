{% extends "base.jinja" %}

{% block title %}Your Cart — {{ site_brand }}{% endblock %}

{% block content %}
<div class="page-bg min-h-screen py-10">
  <div class="max-w-screen-xl mx-auto px-6">
    <h1 class="font-serif text-3xl text-navy-800 mb-8">Your Cart</h1>

    {% if cart|list|length > 0 %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Cart Items -->
      <div class="lg:col-span-2">
        <div id="cart-items">
          {% include 'cart/partials/cart_items.jinja' %}
        </div>
      </div>

      <!-- Order Summary (HTMX-refreshed via #cart-summary OOB) -->
      {% include 'cart/partials/cart_summary.jinja' %}
    </div>
    {% else %}
    <!-- Empty cart -->
    <div class="text-center py-24 bg-white border border-gray-100">
      <svg class="w-20 h-20 text-gray-200 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      <h2 class="font-serif text-2xl text-gray-400 mb-3">Your cart is empty</h2>
      <p class="text-sm text-gray-400 mb-8">Discover our beautiful collection of lab-grown diamond jewelry.</p>
      <a href="{{ url('products:shop') }}" class="btn-navy">Start Shopping &rarr;</a>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}
