<!-- Cart items partial (used by both full cart and HTMX updates) -->
{% if cart|list|length > 0 %}
<div class="space-y-4">
  {% for item in cart %}
  {% if 'product' in item and item.product %}
  <div class="bg-white border border-gray-100 p-4 flex gap-4 items-start shadow-sm" id="cart-item-{{ item.product.id }}">
    <!-- Product image -->
    <a href="{{ url('products:detail', slug=item.product.slug) }}" class="flex-shrink-0 w-20 h-20 bg-gray-50 overflow-hidden">
      <img src="{{ item.product.display_image_url }}" alt="{{ item.product.name }}" class="w-full h-full object-cover">
    </a>

    <!-- Product details -->
    <div class="flex-1 min-w-0">
      <a href="{{ url('products:detail', slug=item.product.slug) }}"
         class="text-xs font-medium tracking-wide uppercase text-gray-800 hover:text-navy-700 transition-colors line-clamp-2">
        {{ item.name }}
      </a>
      {% if item.metal %}
      <p class="text-xs text-gray-400 mt-0.5">Metal: {{ item.metal.replace('_', ' ').title() }}</p>
      {% endif %}
      {% if item.ring_size %}
      <p class="text-xs text-gray-400">Size: {{ item.ring_size }}</p>
      {% endif %}
      <p class="text-sm font-medium text-gray-900 mt-1">Rs. {{ "{:,.2f}".format(item.total_price) }}</p>
    </div>

    <!-- Qty & remove -->
    <div class="flex flex-col items-end gap-2">
      <button hx-post="{{ url('cart:remove', product_id=item.product.id) }}"
              hx-target="#cart-items"
              hx-swap="innerHTML"
              class="text-gray-300 hover:text-red-500 transition-colors" aria-label="Remove">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <div class="flex items-center border border-gray-200">
        <button hx-post="{{ url('cart:update', product_id=item.product.id) }}"
                hx-vals='{"quantity": {{ [item.quantity - 1, 1]|max }}}'
                hx-target="#cart-items" hx-swap="innerHTML"
                class="w-7 h-7 flex items-center justify-center text-gray-500 hover:text-navy-700 hover:bg-gray-50 transition-colors text-sm">−</button>
        <span class="w-8 text-center text-sm text-gray-700">{{ item.quantity }}</span>
        <button hx-post="{{ url('cart:update', product_id=item.product.id) }}"
                hx-vals='{"quantity": {{ item.quantity + 1 }}}'
                hx-target="#cart-items" hx-swap="innerHTML"
                class="w-7 h-7 flex items-center justify-center text-gray-500 hover:text-navy-700 hover:bg-gray-50 transition-colors text-sm">+</button>
      </div>
    </div>
  </div>
  {% endif %}
  {% endfor %}
</div>
{% else %}
<div class="bg-white border border-gray-100 p-10 text-center">
  <p class="text-sm text-gray-400">Your cart is empty.</p>
  <a href="{{ url('products:shop') }}" class="btn-outline mt-4 inline-flex">Start Shopping &rarr;</a>
</div>
{% endif %}
