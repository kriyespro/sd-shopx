{# Cart page Order Summary — swapped OOB on qty/remove #}
<div id="cart-summary"{% if oob|default(false) %} hx-swap-oob="true"{% endif %}
     class="bg-white border border-gray-100 p-6 h-fit shadow-sm">
  {% if cart|list|length > 0 %}
  <h2 class="font-serif text-xl text-navy-800 mb-5 pb-4 border-b border-gray-100">Order Summary</h2>

  <div class="space-y-3 mb-5">
    <div class="flex justify-between text-sm text-gray-600">
      <span>Subtotal</span>
      <span class="font-medium">Rs. {{ "{:,.2f}".format(cart.get_total_price()) }}</span>
    </div>
    <div class="flex justify-between text-sm text-gray-600">
      <span>Shipping</span>
      <span class="text-green-600 font-medium">Free</span>
    </div>
    <div class="flex justify-between text-sm text-gray-600">
      <span>Duties & Taxes</span>
      <span class="text-green-600 font-medium">Included</span>
    </div>
  </div>

  <div class="border-t border-gray-100 pt-4 mb-6">
    <div class="flex justify-between font-medium text-gray-900">
      <span>Total</span>
      <span class="font-serif text-xl">Rs. {{ "{:,.2f}".format(cart.get_total_price()) }}</span>
    </div>
  </div>

  <a href="{{ url('orders:checkout') }}" class="btn-navy w-full py-4 text-sm">
    Proceed to Checkout &rarr;
  </a>

  <a href="{{ url('products:shop') }}" class="btn-outline w-full py-3 text-sm mt-3 justify-center">
    Continue Shopping
  </a>

  <div class="mt-6 pt-5 border-t border-gray-100 flex flex-col gap-2">
    {% for icon_d, label in [
      ('M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', 'Secure Checkout'),
      ('M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945', 'Free Insured Shipping'),
      ('M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', '30-Day Returns'),
    ] %}
    <div class="flex items-center gap-2 text-xs text-gray-500">
      <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ icon_d }}"/></svg>
      {{ label }}
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-sm text-gray-400 text-center py-4">Your cart is empty.</p>
  <a href="{{ url('products:shop') }}" class="btn-outline w-full py-3 text-sm justify-center">Start Shopping</a>
  {% endif %}
</div>
