{% extends "base.jinja" %}

{% block title %}Order Confirmed — {{ site_brand }}{% endblock %}

{% block content %}
<div class="page-bg min-h-screen py-16">
  <div class="max-w-2xl mx-auto px-6">
    <div class="bg-white border border-gray-100 shadow-sm p-10 text-center">
      <!-- Success icon -->
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="font-serif text-3xl text-navy-800 mb-2">Order Confirmed!</h1>
      <p class="text-sm text-gray-500 mb-6">Thank you for your order. We'll send a confirmation to <strong>{{ order.email }}</strong>.</p>

      <div class="bg-gray-50 border border-gray-100 rounded p-4 mb-6 text-left">
        <div class="flex justify-between mb-2">
          <span class="text-xs tracking-wider uppercase text-gray-500">Order Number</span>
          <span class="text-sm font-semibold text-navy-700 font-mono">{{ order.order_number }}</span>
        </div>
        <div class="flex justify-between mb-2">
          <span class="text-xs tracking-wider uppercase text-gray-500">Total</span>
          <span class="text-sm font-semibold text-gray-900">Rs. {{ "{:,.2f}".format(order.total) }}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-xs tracking-wider uppercase text-gray-500">Status</span>
          <span class="text-sm font-medium text-gold-600 capitalize">{{ order.get_status_display() }}</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="{{ url('core:home') }}" class="btn-outline">Continue Shopping</a>
        {% if request.user.is_authenticated %}
        <a href="{{ url('users:order_detail', order_number=order.order_number) }}" class="btn-navy">View Order</a>
        {% else %}
        <a href="{{ url('users:login') }}?next={{ url('users:order_list') }}" class="btn-navy">Sign in to track order</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
