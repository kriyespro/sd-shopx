{% extends "base.jinja" %}

{% block title %}Create Account — {{ site_brand }}{% endblock %}

{% block content %}
<div class="page-bg min-h-screen py-16">
  <div class="max-w-md mx-auto px-6">
    <div class="text-center mb-8">
      <h1 class="font-serif text-3xl text-navy-800">Create Your Account</h1>
      <p class="text-sm text-gray-500 mt-2">Join the {{ site_brand }} family and enjoy exclusive benefits.</p>
    </div>
    <div class="bg-white border border-gray-100 shadow-sm p-8">
      <form method="post" class="space-y-4">
        {{ csrf_input(request) }}
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">First Name</label>
            <input type="text" name="first_name" required placeholder="First" class="form-input">
          </div>
          <div>
            <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Last Name</label>
            <input type="text" name="last_name" required placeholder="Last" class="form-input">
          </div>
        </div>
        <div>
          <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Email</label>
          <input type="email" name="email" required placeholder="your@email.com" class="form-input">
        </div>
        <div>
          <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Password</label>
          <input type="password" name="password1" required placeholder="Min 8 characters" class="form-input">
        </div>
        <div>
          <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Confirm Password</label>
          <input type="password" name="password2" required placeholder="Repeat password" class="form-input">
        </div>
        <button type="submit" class="btn-navy w-full py-4">Create Account &rarr;</button>
      </form>
      <div class="text-center mt-5 pt-5 border-t border-gray-100">
        <p class="text-sm text-gray-500">Already have an account?
          <a href="{{ url('users:login') }}" class="text-navy-700 font-medium hover:underline">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>
{% endblock %}
