{% extends "base.jinja" %}

{% block title %}Login — {{ site_brand }}{% endblock %}

{% block content %}
<div class="page-bg min-h-screen py-16">
  <div class="max-w-md mx-auto px-6">
    <div class="text-center mb-8">
      <h1 class="font-serif text-3xl text-navy-800">Welcome Back</h1>
      <p class="text-sm text-gray-500 mt-2">Sign in to access your account and orders.</p>
    </div>
    <div class="bg-white border border-gray-100 shadow-sm p-8">
      <form method="post" class="space-y-4">
        {{ csrf_input(request) }}
        <div>
          <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Email</label>
          <input type="email" name="email" required placeholder="your@email.com" class="form-input">
        </div>
        <div>
          <label class="text-xs font-medium tracking-widest uppercase text-gray-600 block mb-1">Password</label>
          <input type="password" name="password" required placeholder="••••••••" class="form-input">
        </div>
        <button type="submit" class="btn-navy w-full py-4">Sign In &rarr;</button>
      </form>
      <div class="text-center mt-5 pt-5 border-t border-gray-100">
        <p class="text-sm text-gray-500">Don't have an account?
          <a href="{{ url('users:register') }}" class="text-navy-700 font-medium hover:underline">Create one</a>
        </p>
      </div>
    </div>
  </div>
</div>
{% endblock %}
