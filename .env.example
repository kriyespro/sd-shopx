# Copy to .env and fill in for production. Dev falls back to safe-for-dev defaults if unset.
SECRET_KEY=change-me-to-a-long-random-value
DEBUG=False
ALLOWED_HOSTS=mnxstore.com,www.mnxstore.com,159.195.52.197
CSRF_TRUSTED_ORIGINS=https://mnxstore.com,https://www.mnxstore.com

# Postgres (docker-compose db service) — leave POSTGRES_DB unset to keep using sqlite
POSTGRES_DB=mnxstore
POSTGRES_USER=mnxstore
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (docker-compose redis service)
REDIS_URL=redis://redis:6379/1
