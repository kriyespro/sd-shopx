# Append this to nginx/nginx.conf AFTER certbot has issued the certificate
# (see "SSL install" section in DEPLOY.md). Then:
#   docker compose exec nginx nginx -s reload

server {
    listen 443 ssl;
    server_name mnxstore.com www.mnxstore.com;
    client_max_body_size 20M;

    ssl_certificate     /etc/letsencrypt/live/mnxstore.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mnxstore.com/privkey.pem;

    location /static/ {
        alias /app/staticfiles/;
    }

    location /media/ {
        alias /app/media/;
    }

    location / {
        proxy_pass http://mnxstore;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Optional: once 443 works, redirect plain HTTP -> HTTPS by replacing the
# `location / { proxy_pass ...}` block in the existing `listen 80` server
# with:
#   location / { return 301 https://$host$request_uri; }
# (keep the acme-challenge and static/media locations as-is, Certbot renewal
# still needs the :80 webroot path to work)
