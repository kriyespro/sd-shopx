# /etc/nginx/sites-available/mnxstore.com
# Host nginx -> Docker app on 127.0.0.1:8089
# SSL: Cloudflare Origin Certificate (Full strict)

server {
    listen 80;
    server_name mnxstore.com www.mnxstore.com;
    client_max_body_size 20M;

    location / {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

server {
    listen 443 ssl;
    server_name mnxstore.com www.mnxstore.com;
    client_max_body_size 20M;

    ssl_certificate     /etc/nginx/ssl/mnxstore/cert.pem;
    ssl_certificate_key /etc/nginx/ssl/mnxstore/key.pem;

    location / {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
